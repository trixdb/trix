# =============================================================================
# Trix Local Development — Shared Environment
# =============================================================================
# Copy to .env.local:  cp .env.local.example .env.local
# Or run:              ./scripts/local-setup.sh
#
# This file is loaded by all services via env_file in docker-compose.yml.
# Service-specific overrides (DATABASE_URL, REDIS_URL, etc.) are set
# directly in docker-compose.yml so you don't need to worry about them here.
#
# You only need to fill in API keys and optional settings below.
# =============================================================================

# ===========================================================================
# Required API Keys (at least one LLM + one embedding provider)
# ===========================================================================

# LLM Provider: anthropic (default), openai, gemini, ollama
LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Embedding Provider: openai (default), gemini, ollama, mock
# Set to "mock" to skip embeddings entirely for local dev
EMBEDDING_PROVIDER=openai

# ===========================================================================
# Optional API Keys
# ===========================================================================

# Audio transcription (AssemblyAI or OpenAI Whisper — both optional)
# ASSEMBLYAI_API_KEY=

# Google Gemini (used for simple queries via complexity-aware routing)
# GOOGLE_API_KEY=

# Mistral
# MISTRAL_API_KEY=

# Search reranking (improves search quality, not required)
# COHERE_API_KEY=

# ===========================================================================
# Auth (auto-generated if blank — sessions won't survive API restarts)
# ===========================================================================
# JWT_SECRET=

# ===========================================================================
# Production-required secrets (generate or pull from Railway with --railway)
# ===========================================================================
# Webhook secret for AssemblyAI callbacks
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
ASSEMBLYAI_WEBHOOK_SECRET=
# Internal key for worker status reporting
STATUS_INTERNAL_KEY=
# Encryption key for third-party integration credentials
INTEGRATION_ENCRYPTION_KEY=
# Cookie signing secret
COOKIE_SECRET=

# ===========================================================================
# Optional: Override host ports (defaults avoid common port clashes)
# ===========================================================================
# TRIX_PORT_POSTGRES=15432
# TRIX_PORT_VALKEY=16379
# TRIX_PORT_MINIO_API=19000
# TRIX_PORT_MINIO_UI=19001
# TRIX_PORT_MEMGRAPH=17687
# TRIX_PORT_MEMGRAPH_MON=17444
# TRIX_PORT_API=13737
# TRIX_PORT_WORKERS=19091
# TRIX_PORT_BOTS=13739
# TRIX_PORT_ML_WORKERS=19090
# TRIX_PORT_VISUAL=18090

# ===========================================================================
# Bot Service (trix-bots needs an API key to talk to trix-api)
# ===========================================================================
# Create a service-account API key after first startup:
#   curl -s http://localhost:13737/v1/auth/login \
#     -H 'Content-Type: application/json' \
#     -d '{"email":"robert@zivrio.com","password":"123qwe!\"#QWE"}' | jq -r .token
# Then use that token to create an API key and paste it here.
# TRIX_API_KEY=
